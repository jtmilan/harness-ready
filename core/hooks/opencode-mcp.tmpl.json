{
  "mcp": {
    "agent-teams": {
      "type": "local",
      "command": ["/bin/sh", "-c", "exec '{{SIDECAR}}'"],
      "environment": {
        "AGENT_TEAMS_STATE_DIR": "{{STATE_DIR}}",
        "AGENT_TEAMS_PANE_ID": "{{PANE_ID}}",
        "AGENT_TEAMS_MEMORY_REPO_KEY": "{{REPO_KEY}}",
        "AGENT_TEAMS_TASK_SCOPE": "{{TASK_SCOPE}}"
      },
      "enabled": true
    }
  }
}
