{
  "version": 1,
  "hooks": {
    "sessionStart": [{ "command": "\"{{WRITER}}\" cursor sessionStart {{WSID}}" }],
    "beforeShellExecution": [{ "command": "\"{{WRITER}}\" cursor beforeShellExecution {{WSID}}" }],
    "afterShellExecution": [{ "command": "\"{{WRITER}}\" cursor afterShellExecution {{WSID}}" }],
