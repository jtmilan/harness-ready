<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Plan 05-04 (voice INPUT): Tauri auto-MERGES a src-tauri/Info.plist into the bundle's
  generated Info.plist at build time. The mic usage string is REQUIRED for the in-app
  cpal capture to trigger the macOS TCC prompt instead of crashing (the entitled-app
  side of the 05-03 separation: the app owns the mic, the file-only whisper sidecar
  needs no TCC). Without this key macOS denies mic access outright.
-->
<plist version="1.0">
  <dict>
    <key>NSMicrophoneUsageDescription</key>
    <string>Agent Teams uses the microphone for push-to-talk dictation: you speak a reply to the top agent in the queue and it transcribes locally into the reply field. Audio never leaves your Mac.</string>
  </dict>
</plist>
